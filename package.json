{
  "name": "buagent",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": "18.x || 20.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "rm -rf .next dist node_modules",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:db": "jest src/services/database/__tests__",
    "test:db:coverage": "jest --coverage --collectCoverageFrom='src/services/database/*.ts' --collectCoverageFrom='!src/services/database/__mocks__/*' --collectCoverageFrom='!src/services/database/__tests__/*' src/services/database/__tests__",
    "test:kol": "jest src/services/database/__tests__/KOL2024Service.complete.test.ts",
    "test:insight": "jest src/services/database/__tests__/InsightSearchService.test.ts",
    "test:api": "jest __tests__/integration/api",
    "test:api:kol": "jest __tests__/integration/api/kol.test.ts",
    "test:api:insight": "jest __tests__/integration/api/insight.test.ts",
    "test:api:testing": "jest __tests__/integration/api/testing.test.ts",
    "test:api:ads": "jest __tests__/integration/api/ads.test.ts",
    "test:api:private": "jest __tests__/integration/api/private.test.ts",
    "test:api:coverage": "jest --coverage --collectCoverageFrom='app/api/**/*.ts' --collectCoverageFrom='!app/api/**/*.d.ts' __tests__/integration/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@reduxjs/toolkit": "^2.8.2",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "echarts-wordcloud": "^2.1.0",
    "lru-cache": "^11.1.0",
    "lucide-react": "^0.514.0",
    "next": "^14.2.30",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-redux": "^9.2.0",
    "react-window": "^1.8.11",
    "react-window-infinite-loader": "^1.0.10",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "msw": "^2.10.2",
    "postcss": "^8.4.49",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.0",
    "typescript": "^5.7.2",
    "whatwg-fetch": "^3.6.20"
  }
}
